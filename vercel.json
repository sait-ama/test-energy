{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/proxy.js?originalPath=/api/:path*" },
    { "source": "/api", "destination": "/api/proxy.js?originalPath=/api/" },
    { "source": "/socket.io/:path*", "destination": "/api/proxy.js?originalPath=/socket.io/:path*" },
    { "source": "/socket.io", "destination": "/api/proxy.js?originalPath=/socket.io/" }
  ]
}
